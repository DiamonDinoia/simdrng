% simdrng.mw — mwrap source of truth for the simdrng MATLAB/Octave binding.
%
% This is the ONLY hand-edited MEX source. mwrap turns it into:
%   * simdrng_mex_gen.cpp — the MEX gateway (build tree; regen path);
%   * sr_*.m              — thin per-function stubs.
% Both are checked in under generated/ (default build compiles them directly, no
% mwrap needed). The regen-check CI job re-runs mwrap and fails on drift.
%
% Equivalent manual regeneration (CMake does this for you, then compiles with
% -DR2008OO):
%   mwrap -mex simdrng_mex -c simdrng_mex_gen.cpp -mb simdrng.mw
%
% Design notes:
%   * The handle is an mwrap *object pointer* (simdrng_state*, == simdrng_t).
%     mwrap stores it losslessly as a string and, under -DR2008OO, reads it back
%     from a wrapper class's `mwptr` property — no lossy double round-trip.
%   * mwrap marshals every MATLAB array through mxDOUBLE_CLASS (its
%     mxWrapGetArray_* read mxGetDoubles; its output arrays are mxCreateDoubleMatrix).
%     So 64-bit integers can't ride a typed array losslessly. Two work-arounds:
%       - seed: split into two 32-bit halves (each exact as a double), rejoined in C;
%       - raw u64 output: build the mxUINT64 array in C and return it via mwrap's
%         `mxArray*` pass-through, bypassing the double round-trip entirely.
%   * Element counts (n) are plain doubles (mxWrapGetScalar) cast to int64_t.

$[
#include "simdrng/capi.h"

#include <mex.h>
#include <matrix.h>

#include <stdint.h>

/* mwrap object-pointer type: forward-declared handle (defined in src/capi.cpp).
 * capi.h only typedefs the pointer (simdrng_t), so name the struct here. */
typedef struct simdrng_state simdrng_state;

static simdrng_state *sr_create_w(int kind, double seed_hi, double seed_lo)
{
    /* Rejoin the 64-bit seed from two exact-as-double 32-bit halves. */
    uint64_t seed = ((uint64_t)(uint32_t)seed_hi << 32) | (uint32_t)seed_lo;
    simdrng_t g = simdrng_create((simdrng_kind)kind, seed);
    if (!g)
        mexErrMsgIdAndTxt("simdrng:create", "%s", simdrng_last_error());
    return (simdrng_state *)g;
}

static void sr_free_w(simdrng_state *h) { simdrng_free((simdrng_t)h); }

static int sr_get_kind_w(simdrng_state *h) { return (int)simdrng_get_kind((simdrng_t)h); }

static void sr_fill_double_w(simdrng_state *h, double *y, int64_t n)
{
    simdrng_fill_double((simdrng_t)h, y, (size_t)n);
}

/* Raw uint64 draws as a genuine mxUINT64 column vector (lossless). */
static mxArray *sr_fill_u64_w(simdrng_state *h, int64_t n)
{
    mxArray *out = mxCreateNumericMatrix((mwSize)n, 1, mxUINT64_CLASS, mxREAL);
#if defined(MX_HAS_INTERLEAVED_COMPLEX) && MX_HAS_INTERLEAVED_COMPLEX
    uint64_t *y = mxGetUint64s(out);
#else
    uint64_t *y = (uint64_t *)mxGetData(out);
#endif
    simdrng_fill_u64((simdrng_t)h, y, (size_t)n);
    return out;
}
$]

% -----------------------------------------------------------------------
% Construct: kind is the simdrng_kind enum value; seed the two 32-bit halves.
@function [h] = sr_create(kind, seed_hi, seed_lo)
# simdrng_state* h = sr_create_w(int kind, double seed_hi, double seed_lo);

% -----------------------------------------------------------------------
% Uniform doubles in [0,1). Returns an n-vector (reshaped by the classdef).
@function [y] = sr_fill_double(self, n)
# sr_fill_double_w(simdrng_state* self, output double[n] y, int64_t n);

% -----------------------------------------------------------------------
% Raw uint64 draws (mxArray* pass-through -> genuine uint64 column vector).
@function [y] = sr_fill_u64(self, n)
# mxArray y = sr_fill_u64_w(simdrng_state* self, int64_t n);

% -----------------------------------------------------------------------
% Introspection + free.
@function [k] = sr_get_kind(self)
# int k = sr_get_kind_w(simdrng_state* self);

@function sr_free(self)
# sr_free_w(simdrng_state* self);
