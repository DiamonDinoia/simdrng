@PACKAGE_INIT@

# xsimd/poet are mandatory: the exported target links xsimd and the public
# headers include poet, so consumers need both on their include path.
include(CMakeFindDependencyMacro)
find_dependency(xsimd CONFIG REQUIRED)
find_dependency(poet CONFIG REQUIRED)

include("${CMAKE_CURRENT_LIST_DIR}/simdrngTargets.cmake")
