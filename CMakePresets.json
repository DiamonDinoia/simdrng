{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 16,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_TESTS": "ON",
        "ENABLE_PYTHON": "OFF",
        "MARCH_NATIVE": "ON",
        "BUILD_EXAMPLES": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_TESTS": "ON",
        "ENABLE_PYTHON": "OFF",
        "BUILD_EXAMPLES": "ON"
      }
    },
    {
      "name": "python",
      "displayName": "Python Bindings",
      "inherits": "release",
      "cacheVariables": {
        "ENABLE_PYTHON": "ON",
        "BUILD_EXAMPLES": "OFF"
      }
    },
    {
      "name": "docs",
      "displayName": "Docs",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_TESTS": "OFF",
        "ENABLE_PYTHON": "OFF",
        "BUILD_DOCS": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "release", "configurePreset": "release" },
    { "name": "debug", "configurePreset": "debug" },
    { "name": "python", "configurePreset": "python" },
    { "name": "docs", "configurePreset": "docs", "targets": ["docs"] }
  ],
  "testPresets": [
    {
      "name": "test",
      "configurePreset": "release",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    }
  ]
}
