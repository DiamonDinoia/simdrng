{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "SIMDRNG_DISPATCH": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release (local dev: tests + examples + -march=native benches)",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SIMDRNG_BUILD_TESTS": "ON",
        "SIMDRNG_BUILD_PYTHON": "OFF",
        "SIMDRNG_MARCH_NATIVE": "ON",
        "SIMDRNG_BUILD_EXAMPLES": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug (tests + examples)",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SIMDRNG_BUILD_TESTS": "ON",
        "SIMDRNG_BUILD_PYTHON": "OFF",
        "SIMDRNG_BUILD_EXAMPLES": "ON"
      }
    },
    {
      "name": "python",
      "displayName": "Python Bindings",
      "inherits": "release",
      "cacheVariables": {
        "SIMDRNG_BUILD_PYTHON": "ON",
        "SIMDRNG_BUILD_EXAMPLES": "OFF"
      }
    },
    {
      "name": "docs",
      "displayName": "Docs (Sphinx/Doxygen)",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SIMDRNG_BUILD_TESTS": "OFF",
        "SIMDRNG_BUILD_PYTHON": "OFF",
        "SIMDRNG_BUILD_DOCS": "ON"
      }
    },
    {
      "name": "ci",
      "displayName": "CI (portable: tests + examples, no -march=native)",
      "description": "Release build for the portable CI matrix. -march=native is OFF so binaries stay within the configured/emulated ISA; the SIMD tiers are selected at runtime via xsimd::dispatch. Emulated runs pass -DCMAKE_CROSSCOMPILING_EMULATOR=... on top.",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SIMDRNG_BUILD_TESTS": "ON",
        "SIMDRNG_BUILD_EXAMPLES": "ON",
        "SIMDRNG_BUILD_PYTHON": "OFF",
        "SIMDRNG_MARCH_NATIVE": "OFF"
      }
    },
    {
      "name": "bench",
      "displayName": "Benchmarks (x86-64-v3 baseline)",
      "description": "Release build of the benchmark harness with an AVX2 (x86-64-v3) baseline that every GitHub x86 runner can execute.",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SIMDRNG_BUILD_TESTS": "ON",
        "SIMDRNG_BUILD_EXAMPLES": "OFF",
        "SIMDRNG_BUILD_PYTHON": "OFF",
        "SIMDRNG_MARCH_NATIVE": "OFF",
        "CMAKE_CXX_FLAGS": "-march=x86-64-v3"
      }
    },
    {
      "name": "codspeed",
      "displayName": "CodSpeed instrumentation",
      "description": "RelWithDebInfo benchmark build linked against codspeed-cpp for CodSpeed instrumentation.",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "SIMDRNG_ENABLE_CODSPEED": "ON",
        "CODSPEED_MODE": "instrumentation",
        "SIMDRNG_BUILD_TESTS": "ON",
        "SIMDRNG_BUILD_EXAMPLES": "OFF",
        "SIMDRNG_BUILD_PYTHON": "OFF",
        "SIMDRNG_MARCH_NATIVE": "OFF"
      }
    },
    {
      "name": "sanitizers",
      "displayName": "Sanitizers (ASan + UBSan)",
      "description": "Debug build instrumented with AddressSanitizer + UndefinedBehaviorSanitizer. xsimd::dispatch keeps the AVX-512 tier dormant on lesser CPUs, so no -march guard is needed.",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SIMDRNG_USE_SANITIZERS": "ON",
        "SIMDRNG_BUILD_TESTS": "ON",
        "SIMDRNG_BUILD_EXAMPLES": "OFF",
        "SIMDRNG_BUILD_PYTHON": "OFF",
        "SIMDRNG_MARCH_NATIVE": "OFF"
      }
    },
    {
      "name": "tsan",
      "displayName": "ThreadSanitizer",
      "description": "Debug build instrumented with ThreadSanitizer; pair with the thread-safety tests (per-thread seeding / jump streams).",
      "inherits": "sanitizers",
      "cacheVariables": {
        "SIMDRNG_USE_SANITIZERS": "TSAN"
      }
    },
    {
      "name": "valgrind",
      "displayName": "Valgrind memcheck",
      "description": "RelWithDebInfo build wired for `ctest -T memcheck` under Valgrind.",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "SIMDRNG_BUILD_TESTS": "ON",
        "SIMDRNG_BUILD_EXAMPLES": "OFF",
        "SIMDRNG_BUILD_PYTHON": "OFF",
        "SIMDRNG_MARCH_NATIVE": "OFF",
        "MEMORYCHECK_TYPE": "Valgrind",
        "MEMORYCHECK_COMMAND_OPTIONS": "--leak-check=full --show-leak-kinds=definite,possible --errors-for-leak-kinds=definite --error-exitcode=1 --track-origins=yes --undef-value-errors=yes"
      }
    },
    {
      "name": "static-analysis",
      "displayName": "Static analysis (clang-tidy + cppcheck)",
      "description": "Clang build exporting compile_commands.json for a full clang-tidy + cppcheck sweep. Tests on so the headers are exercised through real TUs.",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "SIMDRNG_BUILD_TESTS": "ON",
        "SIMDRNG_BUILD_EXAMPLES": "OFF",
        "SIMDRNG_BUILD_PYTHON": "OFF",
        "SIMDRNG_MARCH_NATIVE": "OFF"
      }
    },
    {
      "name": "coverage",
      "displayName": "Coverage (gcc + lcov)",
      "description": "Debug build instrumented for line coverage via --coverage.",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SIMDRNG_ENABLE_COVERAGE": "ON",
        "SIMDRNG_BUILD_TESTS": "ON",
        "SIMDRNG_BUILD_EXAMPLES": "OFF",
        "SIMDRNG_BUILD_PYTHON": "OFF",
        "SIMDRNG_MARCH_NATIVE": "OFF"
      }
    },
    {
      "name": "bindings-octave",
      "displayName": "MATLAB/Octave binding (Octave backend)",
      "description": "Builds the C ABI + mwrap MATLAB/Octave binding. With only mkoctfile present the Octave backend is selected; the checked-in gateway is compiled unless SIMDRNG_MATLAB_USE_PREGENERATED=OFF.",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SIMDRNG_BUILD_TESTS": "OFF",
        "SIMDRNG_BUILD_EXAMPLES": "OFF",
        "SIMDRNG_BUILD_PYTHON": "OFF",
        "SIMDRNG_MARCH_NATIVE": "OFF",
        "SIMDRNG_BUILD_C_API": "ON",
        "SIMDRNG_BUILD_MATLAB": "ON"
      }
    },
    {
      "name": "bindings-matlab",
      "displayName": "MATLAB/Octave binding (MATLAB backend)",
      "description": "Same as bindings-octave; with MATLAB on PATH the MATLAB MEX backend is selected by FindMatlab.",
      "inherits": "bindings-octave"
    },
    {
      "name": "bindings-fortran",
      "displayName": "Fortran binding (iso_c_binding)",
      "description": "Builds the C ABI + the Fortran iso_c_binding shim and its self-checking test.",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SIMDRNG_BUILD_TESTS": "OFF",
        "SIMDRNG_BUILD_EXAMPLES": "OFF",
        "SIMDRNG_BUILD_PYTHON": "OFF",
        "SIMDRNG_MARCH_NATIVE": "OFF",
        "SIMDRNG_BUILD_C_API": "ON",
        "SIMDRNG_BUILD_FORTRAN": "ON"
      }
    },
    {
      "name": "bindings-julia",
      "displayName": "Julia binding",
      "description": "Builds the C ABI shared library and registers the Julia package's ctest (needs julia on PATH).",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SIMDRNG_BUILD_TESTS": "OFF",
        "SIMDRNG_BUILD_EXAMPLES": "OFF",
        "SIMDRNG_BUILD_PYTHON": "OFF",
        "SIMDRNG_MARCH_NATIVE": "OFF",
        "SIMDRNG_BUILD_C_API": "ON",
        "SIMDRNG_BUILD_JULIA": "ON"
      }
    },
    {
      "name": "bindings-js",
      "displayName": "JS/TS binding (native N-API addon)",
      "description": "Builds the native Node-API .node addon (links simdrng_c_static) plus the TypeScript layer, and registers the node:test suite. Run 'npm install' in bindings/js first so node-addon-api headers and tsc are present.",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SIMDRNG_BUILD_TESTS": "OFF",
        "SIMDRNG_BUILD_EXAMPLES": "OFF",
        "SIMDRNG_BUILD_PYTHON": "OFF",
        "SIMDRNG_MARCH_NATIVE": "OFF",
        "SIMDRNG_BUILD_C_API": "ON",
        "SIMDRNG_BUILD_JS": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "release", "configurePreset": "release" },
    { "name": "debug", "configurePreset": "debug" },
    { "name": "python", "configurePreset": "python" },
    { "name": "docs", "configurePreset": "docs", "targets": ["docs"] },
    { "name": "ci", "configurePreset": "ci" },
    { "name": "bench", "configurePreset": "bench", "targets": ["benchmarks"] },
    { "name": "codspeed", "configurePreset": "codspeed", "targets": ["benchmarks"] },
    { "name": "sanitizers", "configurePreset": "sanitizers" },
    { "name": "tsan", "configurePreset": "tsan" },
    { "name": "valgrind", "configurePreset": "valgrind" },
    { "name": "static-analysis", "configurePreset": "static-analysis", "targets": ["simdrng"] },
    { "name": "coverage", "configurePreset": "coverage" }
  ],
  "testPresets": [
    {
      "name": "test",
      "configurePreset": "release",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    },
    {
      "name": "ci",
      "configurePreset": "ci",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    },
    {
      "name": "sanitizers",
      "configurePreset": "sanitizers",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    },
    {
      "name": "tsan",
      "configurePreset": "tsan",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    },
    {
      "name": "coverage",
      "configurePreset": "coverage",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    }
  ],
  "workflowPresets": [
    {
      "name": "ci",
      "description": "Configure, build, and test the portable CI preset in one command.",
      "steps": [
        { "type": "configure", "name": "ci" },
        { "type": "build", "name": "ci" },
        { "type": "test", "name": "ci" }
      ]
    }
  ]
}
